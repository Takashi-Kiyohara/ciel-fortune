{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["hnd1"],
  "functions": {
    "src/app/api/chat/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/fortune/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/line/webhook/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/cron/weekly-fortune/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-fortune",
      "schedule": "0 0 * * 1"
    }
  ]
}
